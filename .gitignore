cython_debug/

# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor  
#  Cursor is an AI-powered code editor.`.cursorignore` specifies files/directories to 
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

# Zentra Core - Black Box Protection
# Ignore only data/private folders, NOT the entire directories to avoid losing code
zentra/logs/*
!zentra/logs/.gitkeep

# Memory: Ignore databases and user-specific data, keep source code
zentra/memory/*.db
zentra/memory/*.db-journal
zentra/memory/users/
zentra/memory/vaults/
zentra/memory/core_identity.json
zentra/memory/user_profile.json

# Media: Ignore generated content
zentra/media/audio/*
!zentra/media/audio/.gitkeep
zentra/media/images/*
!zentra/media/images/.gitkeep

# Certs: Ignore generated certificates
zentra/certs/*
!zentra/certs/.gitkeep

# Avatars: Ignore user avatar uploads
zentra/media/avatars/*
!zentra/media/avatars/.gitkeep

# Screenshots: Ignore any captured screenshots
zentra/media/screenshots/*
zentra/core/snapshots/*
snapshots/*

# ── Image files: default BLOCK (privacy - user photos, generated content) ──────
# All image formats are ignored by default...
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.bmp

# ...EXCEPT official Zentra assets (logos, project photos)
!zentra/assets/Tony_Admin.jpg
!zentra/assets/Zentra_Core_Logo.jpg
!zentra/assets/Zentra_Core_Logo_NBG.png
!zentra/assets/Zentra_Core_Logo_NBG\ -\ SQR.png
!zentra/assets/Zentra_Core_Logo_NBG\ -\ SQR.ico
!zentra/assets/Zentra_Core_Project_001.jpg

# ── PERSONA YAML: block all, whitelist only built-ins ─────────────────────
# Block any NEW yaml added to zentra/personality/
zentra/personality/*.yaml
# ...but allow the 7 official built-in personas:
!zentra/personality/Atlas_Man.yaml
!zentra/personality/MacGyver.yaml
!zentra/personality/Motoko Kusanagi.yaml
!zentra/personality/Nova_X-01.yaml
!zentra/personality/Sebastian_Pro.yaml
!zentra/personality/Urania_9800_Woman.yaml
!zentra/personality/Zentra_System_Soul.yaml

# ── PERSONA AVATARS: block custom, whitelist standard 7 ──────────────────
# Block any new avatar folder added to zentra/assets/avatars/
zentra/assets/avatars/*/
# ...but allow the 7 built-in avatar folders and their images:
!zentra/assets/avatars/Atlas_Man/
!zentra/assets/avatars/Atlas_Man/*.png
!zentra/assets/avatars/MacGyver/
!zentra/assets/avatars/MacGyver/*.png
!zentra/assets/avatars/Motoko_Kusanagi/
!zentra/assets/avatars/Motoko_Kusanagi/*.png
!zentra/assets/avatars/Nova_X-01/
!zentra/assets/avatars/Nova_X-01/*.png
!zentra/assets/avatars/Sebastian_Pro/
!zentra/assets/avatars/Sebastian_Pro/*.png
!zentra/assets/avatars/Urania_9800_Woman/
!zentra/assets/avatars/Urania_9800_Woman/*.png
!zentra/assets/avatars/Zentra_System_Soul/
!zentra/assets/avatars/Zentra_System_Soul/*.png

# Config data: Ignore active configs, keep templates
zentra/config/data/*
!zentra/config/data/*.example

# API Keys - CRITICAL: never push these to git
zentra/config/keys.yaml
config/keys.yaml
zentra/config/data/keys.yaml

# Temporary and build files
tmp/
brain/
*.log
*.wav
*.mp3
*.db
.env

# WebUI session / export files (privacy data)
zentra/memory/sessions/
zentra/memory/exports/
zentra/memory/chat_exports/

# System YAML active config (runtime state, not source)
# Uncomment if you don't want to share your personal system.yaml
# zentra/config/data/system.yaml

# Root Level Protection (prevent leakage outside zentra/)
/snapshots/
/logs/
/data/
/data/images/
/zentra/core/snapshots/
/zentra/core/logs/

# Watchdog inhibitor temp file
.config_saved_by_app
