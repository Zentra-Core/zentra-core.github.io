# ── Zentra Audio Subsystem Configuration ──
# Manages the vocal input (microphone) and sound output (speakers, TTS).

# Hardware index and name for Speakers or Headphones (Playback).
output_device_index: 0
output_device_name: Default

# Hardware index and name for the Microphone (Recording).
input_device_index: 0
input_device_name: Default

# If enabled, it will automatically detect and set the system's default 
auto_select: true

# If enabled, emits a short beep on startup
test_on_startup: true

voice_status: true

# ── Piper TTS Configuration (Local Voice Engine) ──
piper_path: C:\piper\piper.exe
onnx_model: C:\piper\it_IT-paola-medium.onnx
speed: 1.0

# ── Push-To-Talk (Walkie-Talkie Mode) ──
push_to_talk: false
ptt_hotkey: ctrl+shift

# ── Audio Data Routing and Paths ──
stt_source: web
tts_destination: web
audio_mode: console
