# ── Zentra Core System Configuration (TEMPLATE) ──
# This is the operational heart of Zentra. It manages artificial intelligence identities,
# local or remote server allocation, API keys, global settings, and active plugins.

ai:
  # The identity currently loaded by the AI. Defines how Zentra behaves.
  active_personality: Zentra_System_Soul.txt

  # This dictionary is automatically populated by scanning the /personality folder.
  available_personalities:
    '1': Zentra_System_Soul.txt

  save_special_instructions: false
  special_instructions: ''

# ── Text Generation Settings (LLM Backend) ──
backend:
  # Options: cloud (LiteLLM), ollama (local), kobold (uncensored local).
  type: cloud

  cloud:
    model: gemini/gemini-2.5-flash
    temperature: 0.7

  kobold:
    url: http://localhost:5001
    model: ''
    max_length: 512
    temperature: 0.8

  ollama:
    model: ''
    num_ctx: 4096
    num_gpu: 25
    temperature: 0.3

# ── Streaming Interface and Connectivity ──
bridge:
  use_processor: true
  chunk_delay_ms: 0
  debug_log: false
  remove_think_tags: true
  local_voice_enabled: false
  webui_voice_enabled: true
  webui_voice_stt: true
  enable_tools: true

# ── Zentra Mental Architecture ──
cognition:
  memory_enabled: true
  episodic_memory: true
  clear_on_restart: false
  include_identity_context: true
  include_self_awareness: true
  max_history_messages: 20

# ── Text Input/Output Security Filter ──
filters:
  remove_asterisks: true
  remove_round_brackets: true
  remove_square_brackets: false
  custom_replacements: {}

# Local system active language
language: en

# ── External Cloud LLM Engines Configurations (LiteLLM) ──
llm:
  allow_cloud: true
  debug_llm: false

  providers:
    gemini:
      api_key: 'YOUR_API_KEY_HERE'
      models:
        - gemini/gemini-2.0-flash
    openai:
      api_key: 'YOUR_API_KEY_HERE'
      models:
        - openai/gpt-4o
    anthropic:
      api_key: 'YOUR_API_KEY_HERE'
      models:
        - anthropic/claude-3-5-sonnet-20240620
    groq:
      api_key: 'YOUR_API_KEY_HERE'
      models:
        - groq/llama-3.3-70b-versatile

logging:
  level: INFO
  destination: console
  message_types: both

# ── Zentra Autonomous Plugins Suite (AI Tools) ──
plugins:
  DASHBOARD:
    enabled: true
  FILE_MANAGER:
    enabled: true
  IMAGE_GEN:
    enabled: true
  MEDIA:
    enabled: true
  WEBCAM:
    enabled: true
  WEB_UI:
    enabled: true
    port: 7070
  DRIVE:
    enabled: true
  AUTOCODER:
    enabled: true
  EXECUTOR:
    # Executive engine allowing the AI to run Python Sandboxes directly on the underlying OS servers
    # for file manipulation or complex mathematical tasks.
    enabled: true
    lazy_load: true
    timeout_seconds: 10

  REMOTE_TRIGGERS:
    # Enables PTT activation via USB buttons, Media Keys (Bluetooth/iPhone), and external webhooks.
    enabled: true
    lazy_load: false
    settings:
      enable_mediasession: true
      enable_volume_keys: true

# Multi-Model Routing Engine
routing_engine:
  mode: auto
  legacy_models: ''

system:
  fast_boot: true
  flask_debug: false
