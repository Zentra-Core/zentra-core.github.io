{
    "extension_id": "media_viewer",
    "parent_plugin": "DRIVE",
    "display_name": "Zentra Media Viewer",
    "version": "1.0.0",
    "description": "Inline media thumbnails (4 size modes) and a full-screen swipeable media player for images, videos and audio in Zentra Drive.",
    "lazy_load": true,
    "config_schema": {
        "default_size": {
            "type": "str",
            "default": "small",
            "options": ["none", "small", "medium", "large"],
            "description": "Default thumbnail size mode."
        },
        "autoplay_video": {
            "type": "bool",
            "default": true,
            "description": "Autoplay video when opened in the lightbox."
        }
    }
}
